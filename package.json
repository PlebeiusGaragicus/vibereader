{
	"name": "vibereader",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"check:lib": "pnpm --filter cyphertap check"
	},
	"dependencies": {
		"@lucide/svelte": "^0.515.0",
		"clsx": "^2.1.1",
		"cyphertap": "workspace:*",
		"epubjs": "^0.3.93",
		"idb": "^8.0.3",
		"mode-watcher": "^1.1.0",
		"nanoid": "^5.1.5",
		"svelte-sonner": "^1.1.1",
		"tailwind-merge": "^3.3.1"
	},
	"devDependencies": {
		"@sveltejs/adapter-static": "^3.0.9",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.0.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.0.0",
		"typescript": "^5.9.3",
		"vite": "^8.0.16"
	}
}
